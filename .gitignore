# ── Monorepo root ──────────────────────────────────────────────────────────
# Cada subproyecto tiene su propio .gitignore (app/.gitignore, backend/.gitignore)
# para sus artefactos de build. Acá solo va lo común a nivel repo.

# Secrets (defensa en profundidad; también ignorados por subproyecto)
**/dart_defines.json
**/.env
.env

# OS
.DS_Store
Thumbs.db

# Editores / IDE
*.log
*.swp
.history
.idea/
*.iml
*.ipr
*.iws

# La carpeta .vscode se versiona (launch configs compartidas), por eso NO se ignora.

# Artefactos de Flutter generados por error en la raíz (el proyecto vive en app/).
/.dart_tool/
/.flutter-plugins-dependencies
/android/
/ios/
/build/
